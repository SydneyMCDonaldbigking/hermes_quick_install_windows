# Hermes 环境配置
# 复制此文件为 .env 并根据实际情况修改

# ===== Python 配置 =====
PYTHON_ENV=development
PYTHON_VERSION=3.11

# ===== Go 配置 =====
GO_ENV=development
GO_VERSION=1.21

# ===== 应用配置 =====
APP_NAME=Hermes
APP_VERSION=0.1.0
APP_DEBUG=true

# ===== API 配置 =====
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ===== Go 服务配置 =====
GO_SERVER_HOST=0.0.0.0
GO_SERVER_PORT=8080

# ===== 日志配置 =====
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===== 数据库配置 (如需要) =====
DB_TYPE=sqlite
DB_PATH=./data/hermes.db
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=hermes
# DB_PASSWORD=password
# DB_NAME=hermes_db

# ===== 其他服务 =====
# REDIS_URL=redis://localhost:6379/0
# RABBITMQ_URL=amqp://guest:guest@localhost/
