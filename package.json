{
  "name": "hermes-launcher",
  "version": "1.0.0",
  "description": "Hermes Agent Windows 一键启动器",
  "main": "src/main.js",
  "homepage": "./",
  "author": {
    "name": "Hermes Team",
    "email": "support@hermes-agent.io"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --publish never",
    "build:portable": "electron-builder --win portable --publish never",
    "build:installer": "electron-builder --win nsis --publish never",
    "build:all": "electron-builder --win --publish never",
    "dist": "electron-builder",
    "pack": "electron-builder --dir",
    "prestart": "npm run check-env",
    "check-env": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/check-env.ps1",
    "gen-assets": "node scripts/gen-assets.cjs",
    "prebuild": "npm run gen-assets"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "cross-env": "^7.0.3",
    "jimp": "^1.6.0",
    "png-to-ico": "^2.1.8"
  },
  "dependencies": {
    "sudo-prompt": "^9.2.1",
    "http-proxy-agent": "^7.0.0",
    "https-proxy-agent": "^7.0.2"
  },
  "build": {
    "appId": "io.hermes.launcher",
    "productName": "Hermes 启动器",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "files": [
      "src/**/*",
      "public/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "certificateFile": null,
      "certificatePassword": null,
      "sign": null,
      "signAndEditExecutable": false,
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Hermes 启动器",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "include": "assets/installer.nsh"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "fileAssociations": []
  }
}
